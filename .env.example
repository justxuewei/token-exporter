LISTEN_PORT=14531
SCRAPE_INTERVAL=300
CCUSAGE_BIN=npx ccusage@latest
CCUSAGE_CODEX_BIN=npx @ccusage/codex@latest
DAYS_BACK=7
CLAUDE_CONFIG_DIR=~/.claude,~/.codefuse/engine/cc
SOURCE=
# Plan names shown in the dashboard (leave empty to hide the panel)
CC_PLAN=
CODEX_PLAN=
# Per-block (5h for CC, daily for Codex) token limits — 0 means "not configured"
CC_BLOCK_LIMIT_TOKENS=0
CODEX_BLOCK_LIMIT_TOKENS=0
# Weekly token limits — 0 means "not configured"
CC_WEEK_LIMIT_TOKENS=0
CODEX_WEEK_LIMIT_TOKENS=0